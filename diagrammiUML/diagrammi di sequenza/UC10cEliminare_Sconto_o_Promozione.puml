@startuml

skinparam actorStyle awesome
title UC10c - Eliminare sconto o promozione

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreOfferte" as GP <<control>>
participant "CatalogoOfferte" as CO <<repository>>
participant "Offerta" as O <<entity>>

N -> IN: Apre sezione offerte
activate IN
IN -> GP: visualizzaOfferteAttive()
activate GP
GP -> CO: cercaOfferteValide()
activate CO
CO --> GP: lista offerte (sconti e promozioni)
deactivate CO
GP --> IN: lista offerte
deactivate GP
IN --> N: mostra elenco completo

N -> IN: Seleziona offerta da eliminare
IN -> GP: eliminaOfferta(idOfferta)
activate GP

GP -> CO: eliminaOfferta(idOfferta)
activate CO
CO --> GP: conferma
deactivate CO

GP --> IN: esito positivo
deactivate GP
IN --> N: mostra "Offerta eliminata con successo"
deactivate IN
@enduml