@startuml
title UC12c - Eliminare fornitore
skinparam actorStyle awesome

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreFornitori" as GF <<control>>
participant "CatalogoFornitori" as CF <<repository>>
participant "CatalogoArticoli" as CA <<repository>>
participant "Fornitore" as F <<entity>>

N -> IN: Seleziona fornitore da eliminare
activate IN
IN -> GF: getFornitore(id)
activate GF
GF -> CF: trovaPerId(id)
activate CF
CF --> GF: fornitore
deactivate CF
GF --> IN: dettagli fornitore
deactivate GF
IN --> N: mostra dettagli e chiede conferma

N -> IN: Conferma eliminazione
IN -> GF: eliminaFornitore(id)
activate GF

GF -> CF: trovaPerid(id)
activate CF
CF --> GF: fornitore
deactivate CF

alt fornitore non trovato
    GF --> IN: ValueError "Fornitore con id={id} non trovato."
    IN --> N: mostraErrore()
else fornitore trovato
    GF -> CA: articoliDelFornitore(fornitoreId)
    activate CA
    CA --> GF: lista articoli collegati
    deactivate CA

    loop per ogni articolo del fornitore
        GF -> CA: salvaArticolo(articolo)
        activate CA
        CA --> GF: conferma
        deactivate CA
    end

    GF -> CF: rimuoviFornitore(fornitore)
    activate CF
    CF --> GF: conferma
    deactivate CF

    GF --> IN: esito positivo
    deactivate GF
    IN --> N: mostra "Fornitore eliminato con successo"
end

deactivate IN
@enduml