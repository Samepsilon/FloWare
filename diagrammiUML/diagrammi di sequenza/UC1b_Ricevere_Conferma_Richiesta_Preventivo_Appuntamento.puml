@startuml

skinparam actorStyle awesome

title UC1b - Ricevere conferma richiesta preventivo o appuntamento

actor Cliente
participant "InterfacciaCliente" as BoundaryCli <<boundary>>
participant "SistemaRichieste" as Control <<control>>
participant "ArchivioRichieste" as RepoRichiesta <<repository>>
participant "NotificaRepository" as RepoNotifica <<repository>>
participant "Richiesta" as Richiesta <<entity>>

note over Cliente : UC1b inizia a seguito della conferma del Negoziante (UC7)

Cliente -> BoundaryCli : apre notifica
activate BoundaryCli
BoundaryCli -> Control : getDettagliRichiesta(idRichiesta)
activate Control

Control -> RepoRichiesta : getDettagliConferma(idRichiesta)
activate RepoRichiesta

RepoRichiesta -> Richiesta : trovaPerId(idRichiesta)
activate Richiesta
Richiesta --> RepoRichiesta : richiesta
deactivate Richiesta

RepoRichiesta -> Richiesta : getDataOra()
activate Richiesta
Richiesta --> RepoRichiesta : data, ora
deactivate Richiesta

RepoRichiesta --> Control : dettagliConferma(data, ora)
deactivate RepoRichiesta

Control --> BoundaryCli : mostraDettagli(data, ora)
deactivate Control
BoundaryCli --> Cliente : visualizza dettagli conferma
deactivate BoundaryCli

activate Control
Control -> RepoNotifica : segnaComeLetta(idNotifica)
activate RepoNotifica
RepoNotifica --> Control : conferma aggiornamento
deactivate RepoNotifica
deactivate Control

BoundaryCli -> Cliente : mostraConferma("Richiesta confermata dal negoziante")

Control -> RepoRichiesta : cercaRichiesta(richiesta)
activate Control
activate RepoRichiesta
RepoRichiesta --> Control : richiestaTrovata
deactivate RepoRichiesta

Control -> RepoNotifica : creaNotifica(cliente, "Confermata")
activate RepoNotifica
RepoNotifica --> Control : notifica
deactivate RepoNotifica
deactivate Control

BoundaryCli -> Control : recuperaRichieste(clienteId)
activate Control
Control -> RepoRichiesta : trovaPerCliente(clienteId)
activate RepoRichiesta
RepoRichiesta --> Control : listaRichieste
deactivate RepoRichiesta
Control --> BoundaryCli : richieste
deactivate Control
BoundaryCli --> Cliente : mostraElencoRichieste(richieste)

@enduml