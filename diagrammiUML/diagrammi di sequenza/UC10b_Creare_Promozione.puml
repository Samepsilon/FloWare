@startuml
skinparam actorStyle awesome
title UC10b - Creazione promozione

actor Negoziante as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreOfferte" as G <<control>>
participant "CatalogoOfferte" as CO <<repository>>
participant "CatalogoArticoli" as CA <<repository>>
participant "Promozione" as P <<entity>>
participant "Articolo" as A <<entity>>

N -> IN: Accede a "Gestione Offerte"
activate IN
IN -> G: visualizzaOfferteAttive()
activate G
G -> CO: cercaPromozioni()
activate CO
CO --> G: elenco promozioni
deactivate CO
G --> IN: elenco promozioni
IN --> N: Mostra promozioni esistenti
deactivate G
deactivate IN

N -> IN: Clicca "Crea promozione"
activate IN
IN -> IN: mostraModuloCreazionePromozione()
deactivate IN
N -> IN: Inserisce dati (nome, condizioni, data inizio, data fine, prodotti coinvolti)

break Annullamento
    N -> IN: Clicca "Annulla"
    activate IN
    IN --> N: mostraMessaggio("Operazione annullata")
    IN -> IN: Chiudi modulo
    deactivate IN
end

activate IN
IN -> G: creaPromozione(datiPromozione)
activate G
G -> G: validaDatiPromozione(datiPromozione)

alt dataFine < dataInizio
    G --> IN: mostraErrore("Data fine non valida: deve essere successiva alla data inizio")
    IN --> N: Mostra errore
    
else condizioni non specificate
    G --> IN: mostraErrore("Condizioni promozione non specificate")
    IN --> N: Mostra errore
    
else dati validi
    G -> CA: verificaProdotti(listaProdottiSelezionati)
    activate CA
    CA --> G: prodottiValidi
    deactivate CA
    
    alt uno o più prodotti non presenti
        G --> IN: mostraErrore("Uno o più prodotti selezionati non sono presenti nel catalogo")
        IN --> N: Mostra errore
        
    else prodotti presenti
        G -> CO: salvaPromozione(datiPromozione)
        activate CO
        CO -> P: <<create>> Promozione(dati)
        activate P
        deactivate P
        CO --> G: idPromozione
        deactivate CO
        
        loop Per ogni articolo in listaProdottiSelezionati
            G -> CA: associaPromozioneAdArticolo(articolo, promozione)
            activate CA
            CA -> A: applica la Promozione 
            activate A
            A --> CA: conferma
            deactivate A
            deactivate CA
        end
        
        G --> IN: mostraConferma("Promozione creata e associata ai prodotti selezionati")
        IN --> N: mostraMessaggio("Promozione creata con successo")
        
        IN -> G: aggiornaListaOfferte()
        G -> CO: cercaPromozioni()
        activate CO
        CO --> G: elenco aggiornato
        deactivate CO
        G --> IN: elenco aggiornato
        IN --> N: Mostra elenco promozioni aggiornato
    end
end

deactivate G
deactivate IN
@enduml