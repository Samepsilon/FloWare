@startuml
title UC9a - Aggiungere articolo
skinparam actorStyle awesome

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreCatalogo" as GC <<control>>
participant "CatalogoArticoli" as CA <<repository>>
participant "CatalogoFornitori" as CF <<repository>>
participant "Articolo" as A <<entity>>

N -> IN: Richiede di aggiungere un articolo
activate IN
IN --> N: mostraFormAggiuntaArticolo
deactivate IN

N -> IN: Inserisce (nome, descrizione, prezzo, fornitore)
activate IN
IN -> GC: aggiungiArticolo(nome, descrizione, prezzo, fornitore_id, disponibile)
activate GC
deactivate IN

opt fornitore_id != None
    GC -> CF: cercaFornitore(id)
    activate CF
    CF --> GC: fornitore (o None)
    deactivate CF

    alt fornitore non trovato
        GC --> IN: ValueError "Fornitore con id={fornitore_id} non esiste."
        IN --> N: mostraErrore()
    end
end

create A
GC -> A: <<create>> Articolo(nome, descrizione, prezzo, disponibile, fornitore_id)

GC -> CA: salvaArticolo(articolo)
activate CA
CA --> GC: articolo salvato
deactivate CA

GC --> IN: esito positivo
deactivate GC
IN --> N: mostra "Articolo aggiunto con successo"
deactivate IN
@enduml