@startuml
title UC12a - Aggiungere nuovo fornitore
skinparam actorStyle awesome

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreFornitori" as GF <<control>>
participant "CatalogoFornitori" as CF <<repository>>
participant "Fornitore" as F <<entity>>

N -> IN: Apre sezione fornitori
activate IN
IN -> GF: visualizzaFornitori()
activate GF
GF -> CF: caricaListaForniori()
activate CF
CF --> GF: lista fornitori
deactivate CF
GF --> IN: lista fornitori
deactivate GF
IN --> N: mostra elenco fornitori

N -> IN: Clicca "Aggiungi fornitore"
IN --> N: mostra form (nome, contatti, tipologia, servizioDomicilio)

N -> IN: Inserisce dati fornitore
IN -> GF: aggiungiFornitore(nome, contatti, tipologia, servizioDomicilio)
activate GF

GF -> GF: validaDatiFornitore(nome, contatti, tipologia)

alt validazione fallita
    GF --> IN: ValueError (es. "Il nome del fornitore non può essere vuoto.")
    IN --> N: mostraErrore()
else dati validi
    GF -> CF: caricaListaForniori()
    activate CF
    CF --> GF: lista esistente
    deactivate CF

    alt fornitore duplicato (stesso nome)
        GF --> IN: ValueError "Esiste già un fornitore con nome '{nome}'."
        IN --> N: mostraErrore()
    else nome univoco
        create F
        GF -> F: <<create>> Fornitore(nome, contatti, tipologia, servizioDomicilio)

        GF -> CF: salvaFornitore(fornitore)
        activate CF
        CF --> GF: fornitore salvato
        deactivate CF

        GF --> IN: esito positivo
        deactivate GF
        IN --> N: mostra "Fornitore aggiunto con successo"
    end
end

deactivate IN
@enduml