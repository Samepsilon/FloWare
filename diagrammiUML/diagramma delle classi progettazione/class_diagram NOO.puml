@startuml
title Diagramma delle Classi Diviso in Package - Sistema Negozio

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam classBackgroundColor #FEFEFE
skinparam classBorderColor #555
skinparam arrowColor #333
skinparam packageBackgroundColor #FFFEEB
skinparam packageBorderColor #AAA

' =========================================================================
' PACKAGE AUTENTICAZIONE
' =========================================================================
package "Package Autenticazione" <<Folder>> {
    class Utente {
        - id : Long
        - username : String
        - email : String
        - password : String
        - ruolo : String
        --
        + getRuolo() : String
        + getUsername() : String
        + getPassword() : String
        + getEmail() : String
    }
    class Cliente {
    }
    class Negoziante {
    }

    Utente <|-- Cliente
    Utente <|-- Negoziante

    class "InterfacciaLogin" <<boundary>> {
        + richiediCredenziali() : void
        + mostraErrore(messaggio : String) : void
        + mostraFormRegistrazione() : void
        + mostraConfermaRegistrazione(messaggio : String) : void
        + reindirizzaPerRuolo(ruolo : String) : void
    }

    class SistemaRegistrazione <<control>> {
        + inviaRegistrazione(username : String, email : String, password : String, ruolo : String) : Utente
        + verificatoFormatoEmail(mail : String) : Boolean
        + verificatoCriteriPassword(password : String) : Boolean
        + confrontaPassword(password : String, conferma : String) : Boolean
    }

    class SistemaAccesso <<control>> {
        + inviaCredenziali(username : String, password : String) : void
        + impostaSessione(ruolo : String) : void
        + reindirizzaPerRuolo(ruolo : String) : void
        + getSessione() : void
        + confrontaPassword(password : String, conferma : String) : Boolean
        + verificatoFormatoEmail(mail : String) : Boolean
    }

    class UtenteRepository <<repository>> {
        + salva_utente(utente : Utente) : Utente
        + trova_utente(id : Long) : Utente
        + trova_per_username(username : String) : Utente
        + trova_per_email(email : String) : Utente
        + elimina_utente(id : Long) : void
        + tutti_i_clienti() : List<Cliente>
        + tutti_i_negozianti() : List<Negoziante>
    }

    "InterfacciaLogin" ..> SistemaRegistrazione : registrazione
    "InterfacciaLogin" ..> SistemaAccesso : login
    SistemaRegistrazione ..> UtenteRepository
    SistemaAccesso ..> UtenteRepository
    UtenteRepository ..> Utente
    UtenteRepository ..> Cliente
    UtenteRepository ..> Negoziante
}

' =========================================================================
' PACKAGE NOTIFICHE & RICHIESTE
' =========================================================================
package "Package Notifiche" <<Folder>> {
    class Richiesta {
        - id : Long
        - tipo : String
        - stato : String
        - data : Date
        - ora : String
        - contatti : String
        - descrizione : String
        - clienteId : Long
        --
        + setStato(stato : String) : void
        + getStato() : String
        + getDataOra() : String
    }

    class Consegna {
        - id : Long
        - regione : String
        - citta : String
        - via : String
        - civico : String
        - stato : String
        - clienteId : Long
        --
        + setStato(nuovoStato : String) : void
        + getStato() : String
        + getClienteId() : Long
    }

    class SlotOrario {
        - id : Long
        - data : Date
        - fasciaOraria : String
        --
        + impostaData(data : Date) : void
    }

    class Notifica {
        - id : Long
        - destinatario : String
        - messaggio : String
        - letta : Boolean
        - tipo : String
        - richiestaId : Long
    }

    class SistemaRichieste <<control>> {
        + richiediOpzioni() : List<String>
        + inviaRichiesta(richiesta : Richiesta) : void
        + annullaRichiesta(idRichiesta : Long) : void
        + recuperaRichieste(clienteId : Long) : List<Richiesta>
        + getDettagliRichiesta(idRichiesta : Long) : Richiesta
        + recuperaDateDisponibili() : List<Date>
        + recuperaFasceOrarie(data : Date) : List<String>
        + confermaScelta(data : Date, ora : String) : void
    }

    class GestoreConsegne <<control>> {
        + confermaRichiesta(dati : Object) : void
        + cercaConsegne() : List<Consegna>
        + aggiornaStatoConsegna(idConsegna : Long, nuovoStato : String) : void
    }

    class GestoreNotifiche <<control>> {
        + visualizzaNotifiche() : List<Notifica>
        + confermaAppuntamento(richiesta : Richiesta) : void
        + confermaPreventivo(richiesta : Richiesta) : void
        + inviaNotificaCliente(notifica : Notifica) : void
        + confermaRichiesta(richiesta : Richiesta, tipo_atteso : String) : void
        + visualizzaConsegne() : void
    }

    class ArchivioRichieste <<repository>> {
        + salva_richiesta(richiesta : Richiesta) : Richiesta
        + trovaPerId(id : Long) : Richiesta
        + trovaPerCliente(clienteId : Long) : List<Richiesta>
        + getDettagliConferma(id : Long) : Richiesta
        + verificaAnnullamento(richiesta : Richiesta) : Boolean
        + aggiornaStatoRichiesta(id : Long, nuovo_stato : String) : Richiesta
        + richiesteInAttesa() : List<Richiesta>
    }

    class ConsegnaRepository <<repository>> {
        + salva_consegna(consegna : Consegna) : Consegna
        + trova_consegna(id : Long) : Consegna
        + consegne_del_cliente(clienteId : Long) : List<Consegna>
        + consegne_per_stato(stato : String) : List<Consegna>
        + elimina_consegna(id : Long) : void
    }

    class NotificaRepository <<repository>> {
        + segna_come_letta(idNotifica : Long) : Boolean
        + salvaNotifica(notifica : Notifica) : Notifica
        + trovaNotifica(id : Long) : Notifica
        + notificheDelDestinatario(destinatario : String) : List<Notifica>
        + notificheNonLette() : List<Notifica>
        + notifichePerTipo(tipo : String) : List<Notifica>
        + notifichePerRichiesta(richiestaId : Long) : List<Notifica>
        + eliminaNotifica(id : Long) : void
    }

    class ArchivioCalendario <<repository>> {
        + trovaDateLibere() : List<Date>
        + trovaFascePerData(data : Date) : List<String>
        + salvaScelta(data : Date, ora : String) : void
    }

    Richiesta "1" --> "0..1" SlotOrario : occupa
    Richiesta "1" --> "0..*" Notifica : genera
    Consegna "1" --> "0..*" Notifica : genera

    SistemaRichieste ..> ArchivioRichieste
    SistemaRichieste ..> ArchivioCalendario
    GestoreConsegne ..> ConsegnaRepository
    GestoreConsegne ..> NotificaRepository
    GestoreConsegne ..> UtenteRepository
    GestoreNotifiche ..> NotificaRepository
    GestoreNotifiche ..> ArchivioRichieste

    ArchivioRichieste ..> Richiesta
    ConsegnaRepository ..> Consegna
    NotificaRepository ..> Notifica
    ArchivioCalendario ..> SlotOrario
}

' =========================================================================
' PACKAGE LOCALE (ORARI, ARTICOLI E OFFERTE)
' =========================================================================
package "Package Locale" <<Folder>> {
    class Orario {
        - id : Long
        - giorno : String
        - apertura : String
        - chiusura : String
        - tipo : String
        - dataSpecifica : Date
        --
        + getDettagliOrario() : String
        + aggiornaOrario(apertura : String, chiusura : String) : void
    }

    class Articolo {
        - id : Long
        - nome : String
        - descrizione : String
        - prezzo : Double
        - quantita : int
        - disponibile : Boolean
        - fornitore_id : Long
        - percentuale : Double
        --
        + getDettagli() : String
        + applicaSconto(sconto : Sconto) : void
        + rimuoviOfferta() : void
        + getPrezzo() : Double
    }

    abstract class Offerte {
        - id : Long
        - dataInizio : Date
        - dataFine : Date
        - ruolo : String
    }

    class Sconto {
        - evento : String
        - percentuale : Double
        --
        + getPercentuale() : Double
    }

    class Promozione {
        - descrizione : String
    }

    class Fornitore {
        - id : Long
        - nome : String
        - contatti : String
        - tipologia : String
        - servizioDomicilio : Boolean
    }

    class OrarioRepository <<repository>> {
        + orari_settimanali() : List<Orario>
        + orari_speciali() : List<Orario>
        + orari_per_giorno(giorno : String) : List<Orario>
        + orari_per_data(dataSpecifica : Date) : List<Orario>
        + salva_orario(orario : Orario) : Orario
        + trova_orario(id : Long) : Orario
        + elimina_orario(id : Long) : void
        + elimina_orari_per_giorno(giorno : String) : void
    }

    class CatalogoArticoli <<repository>> {
        + salvaArticolo(articolo : Articolo) : Articolo
        + trovaPerId(id : Long) : Articolo
        + rimuoviArticolo(id : Long) : void
        + getArticoliDisponibili() : List<Articolo>
        + articoliDelFornitore(fornitore_id : Long) : List<Articolo>
    }

    class CatalogoOfferte <<repository>> {
        + salva_offerta(offerta : Offerte) : Offerte
        + trova_offerta(id : Long) : Offerte
        + elimina_offerta(id : Long) : void
        + offre_attive(data_riferimento : Date) : List<Offerte>
        + offre_per_tipo(tipo : String) : List<Offerte>
        + promozioni() : List<Promozione>
        + sconti() : List<Sconto>
    }

    class CatalogoFornitori <<repository>> {
        + caricaListaForniori() : List<Fornitore>
        + trova_fornitore(id : Long) : Fornitore
        + salva_fornitore(fornitore : Fornitore) : Fornitore
        + rimuoviFornitore(id : Long) : void
    }

    class SistemaInfoNegozio <<control>> {
        + richiediOrari() : List<Orario>
    }

    class SistemaCatalogo <<control>> {
        + visualizzaCatalogo() : List<Articolo>
        + richiediDettagli(idArticolo : Long) : Articolo
    }

    class SistemaOfferte <<control>> {
        + recuperaOfferteAttive() : List<Promozione>
        + visualizzaOfferteAttive() : List
    }

    class GestoreCatalogo <<control>> {
        + aggiungi_articolo(nome : String, descrizione : String, prezzo : Double, fornitore_id : Long, disponibile : Boolean) : Articolo
        + aggiorna_articolo(id : Long, nome : String, descrizione : String, prezzo : Double, disponibile : Boolean, fornitore_id : Long) : Articolo
        + rimuovi_articolo(id : Long) : void
        + get_catalogo() : List<Articolo>
        + get_catalogo_disponibile() : List<Articolo>
        + get_articoli_in_sconto() : List<Articolo>
        + cerca_per_nome(nome : String) : List<Articolo>
        + cerca_per_fascia_prezzo(minimo : Double, massimo : Double) : List<Articolo>
        + applica_sconto(id : Long, percentuale : Double) : Articolo
        + rimuovi_sconto(id : Long) : Articolo
        + segna_disponibile(id : Long, disponibile : Boolean) : Articolo
    }

    class GestorePromozioni <<control>> {
        + valida_date(data_inizio : Date, data_fine : Date) : void
        + visualizza_sconti() : List<Sconto>
    }

    class GestoreOfferte <<control>> {
        + creaSconto(dati : Object) : void
        + validaDatiSconto(dati : Object) : Boolean
        + creaPromozione(dati : Object) : void
        + validaDatiPromozione(dati : Object) : Boolean
        + eliminaOfferta(id : Long, tipo : String) : void
        + aggiornaListaSconti() : void
        + aggiornaListaOfferte() : void
        + visualizzaOfferteAttive() : List<Promozione>
        + visualizzaScontiAttivi() : List<Sconto>
    }

    class GestoreOrari <<control>> {
        + visualizzaOrari() : List<Orario>
        + aggiornaOrarioSettimanale(giorno : String, nuoviOrari : Object) : void
        + validaOrario(nuoviOrari : Object) : Boolean
        + impostaChiusuraStraordinaria(data : Date) : void
        + impostaOrarioTemporaneo(data : Date, orario : Object) : void
        + aggiornaVisualizzazioneOrari() : List<Orario>
    }

    class GestoreFornitori <<control>> {
        + aggiungiFornitore(nome : String, contatti : String, tipologia : String, servizioDomicilio : Boolean) : Fornitore
        + validaDatiFornitore(nome : String, contatti : String, tipologia : String) : void
        + modificaFornitore(id : Long, nome : String, contatti : String, tipologia : String, domicilio : Boolean) : Fornitore
        + eliminaFornitore(id : Long) : void
        + getFornitore(id : Long) : Fornitore
        + visualizzaFornitori() : List<Fornitore>
    }

    class "InterfacciaCliente" <<boundary>> {
        + mostraDashboardCliente() : void
        + mostraCampi(tipo : String) : void
        + mostraElencoRichieste(richieste : List<Richiesta>) : void
        + mostraCatalogo(articoli : List<Articolo>) : void
        + mostraDettagliArticolo(dettagli : Map) : void
        + mostraTabellaOrari(orari : List<Orario>) : void
        + mostraOfferte(offerte : List<Promozione>) : void
        + mostraMessaggio(messaggio : String) : void
        + mostraConferma(messaggio : String) : void
        + mostraErrore(messaggio : String) : void
    }

    class "InterfacciaNegoziante" <<boundary>> {
        + mostraDashboardNegoziante() : void
        + mostraElencoArticoli(articoli : List<Articolo>) : void
        + mostraModuloInserimentoArticolo() : void
        + mostraModuloModificaArticolo(dati : Map) : void
        + mostraElencoFornitori(fornitori : List<Fornitore>) : void
        + mostraModuloInserimentoFornitore() : void
        + mostraModuloModificaFornitore(dati : Map) : void
        + mostraTabellaOrariConModifica(orari : List<Orario>) : void
        + mostraModuloOrario(data : Date) : void
        + mostraElencoSconti(sconti : List<Sconto>) : void
        + mostraElencoPromozioni(promozioni : List<Promozione>) : void
        + mostraModuloCreazioneSconto() : void
        + mostraModuloCreazionePromozione() : void
        + mostraElencoNotifiche(notifiche : List<Notifica>) : void
        + mostraDettagliRichiesta(richiesta : Richiesta) : void
        + mostraDettagliConsegna(consegna : Consegna) : void
        + mostraConferma(messaggio : String) : void
        + mostraErrore(messaggio : String) : void
    }

    Offerte <|-- Sconto
    Offerte <|-- Promozione
    Fornitore "1" --> "0..*" Articolo : possiede
    Articolo "1" --> "0..*" Offerte : associato

    InterfacciaCliente ..> SistemaCatalogo
    InterfacciaCliente ..> SistemaOfferte
    InterfacciaCliente ..> SistemaInfoNegozio
    InterfacciaCliente ..> GestoreConsegne
    InterfacciaCliente ..> SistemaRichieste

    InterfacciaNegoziante ..> GestoreCatalogo
    InterfacciaNegoziante ..> GestoreFornitori
    InterfacciaNegoziante ..> GestoreOrari
    InterfacciaNegoziante ..> GestoreOfferte
    InterfacciaNegoziante ..> GestorePromozioni
    InterfacciaNegoziante ..> GestoreNotifiche

    SistemaCatalogo ..> CatalogoArticoli
    SistemaOfferte ..> CatalogoOfferte
    SistemaInfoNegozio ..> OrarioRepository
    GestoreConsegne ..> ConsegnaRepository
    GestoreConsegne ..> NotificaRepository
    GestoreConsegne ..> UtenteRepository
    GestoreCatalogo ..> CatalogoArticoli
    GestorePromozioni ..> CatalogoOfferte
    GestoreOfferte ..> CatalogoOfferte
    GestoreOfferte ..> CatalogoArticoli
    GestoreOrari ..> OrarioRepository
    GestoreFornitori ..> CatalogoFornitori

    CatalogoArticoli ..> Articolo
    CatalogoOfferte ..> Offerte
    OrarioRepository ..> Orario
    CatalogoFornitori ..> Fornitore
}

' =========================================================================
' CROSS-PACKAGE RELATIONS (Package Notifiche -> Autenticazione, Locale -> Notifiche)
' =========================================================================

' Cliente and Negoziante from Autenticazione used in Notifiche and Locale
SistemaRichieste ..> ArchivioRichieste
InterfacciaCliente ..> SistemaRichieste

' NotificaRepository used by GestoreConsegne (Locale) and GestoreNotifiche (Notifiche)
NotificaRepository ..> Notifica

' UtenteRepository used across packages
UtenteRepository ..> Utente
UtenteRepository ..> Cliente
UtenteRepository ..> Negoziante

' Entity relationships across packages
Cliente "1" --> "0..*" Richiesta : possiede
Cliente "1" --> "0..*" Consegna : possiede
Negoziante "1" --> "0..*" Fornitore : gestisce
Negoziante "1" --> "0..*" Articolo : gestisce
Negoziante "1" --> "1..*" Consegna : effettua
Negoziante "1" --> "0..*" Offerte : assegna
Cliente "1" --> "1" Orario : seleziona

@enduml