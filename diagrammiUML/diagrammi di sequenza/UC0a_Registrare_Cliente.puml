@startuml
title UC0a - Registra Cliente
skinparam actorStyle awesome
actor Cliente

participant "InterfacciaLogin" <<boundary>>
participant "SistemaRegistrazione" as Sistema <<control>>
participant "UtenteRepository" as Repo <<repository>>

Cliente -> InterfacciaLogin : Accede alla pagina di registrazione
activate InterfacciaLogin
InterfacciaLogin -> Cliente : mostraFormRegistrazione()
deactivate InterfacciaLogin

Cliente -> InterfacciaLogin : Inserisce username, e-mail, password, conferma password
activate InterfacciaLogin
InterfacciaLogin -> Sistema : inviaRegistrazione(dati)
activate Sistema
deactivate InterfacciaLogin

Sistema -> Repo : trovaPerUsername(username)
activate Repo
Repo --> Sistema : cliente (o null)
deactivate Repo

opt Username non univoco
    Sistema -> InterfacciaLogin : Errore "Username già in uso. Scegline un altro"
    activate InterfacciaLogin
    InterfacciaLogin -> Cliente : mostraErrore()
    deactivate InterfacciaLogin
end  

Sistema -> Sistema : verificaFormatoEmail(email)
opt E-mail non valida
    Sistema -> InterfacciaLogin : Errore "Inserire un indirizzo email valido"
    activate InterfacciaLogin
    InterfacciaLogin -> Cliente : mostraErrore()   
    deactivate InterfacciaLogin
end

Sistema -> Sistema : VerificaCriteriPassword(min 8 car., 1 num, 1 spec)
opt Password non valida
    Sistema -> InterfacciaLogin : Mostra criteri richiesti
    activate InterfacciaLogin
    InterfacciaLogin -> Cliente : mostraErrore()
    deactivate InterfacciaLogin
end    


Sistema -> Sistema : ConfrontaPassword(password, conferma)
opt Le password non coincidono
    Sistema -> InterfacciaLogin : Errore "Le password non corrispondono"
    activate InterfacciaLogin
    InterfacciaLogin -> Cliente : mostraErrore()
    deactivate InterfacciaLogin
end

create nuovoCliente
Sistema -> nuovoCliente : <<create>> Cliente(username, email, password)

Sistema -> Repo : salva(nuovoCliente)
activate Repo
Repo --> Sistema : conferma salvataggio
deactivate Repo


Sistema -> InterfacciaLogin : Mostra "Account Cliente creato con successo"
activate InterfacciaLogin
Sistema -> InterfacciaLogin : reindirizzaLogin()
InterfacciaLogin -> Cliente : Mostra conferma e pagina login
deactivate InterfacciaLogin

deactivate Sistema

@enduml



