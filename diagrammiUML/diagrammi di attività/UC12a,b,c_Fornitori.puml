@startuml
title UC12a,b,c - Aggiungere/Modificare/Eliminare Fornitore
start
:Il Negoziante accede a "Gestione Fornitori";
:Il sistema visualizza l'elenco fornitori;
:Il Negoziante seleziona operazione;

if (Aggiungi) then 
  :Inserisci dati nuovo fornitore;
  if (Dati validi?) then (si)
    :Salva fornitore;
    :Messaggio "Fornitore aggiunto con successo";
  else (no)
    :Mostra errore;
  endif
elseif (Modifica) then 
  :Seleziona fornitore;
  :Modifica dati;
  if (Dati validi?) then (si)
    :Salva modifiche;
    :Messaggio "Fornitore modificato";
  else (no)
    :Mostra errore;
  endif
elseif (Rimuovere) then 
  :Seleziona fornitore;
  :Conferma rimozione;
  if (Confermato) then (sì)
    :Rimuovi fornitore;
    :Messaggio "Fornitore rimosso";
  else (no)
    :Operazione annullata;
  endif
endif
stop
@enduml