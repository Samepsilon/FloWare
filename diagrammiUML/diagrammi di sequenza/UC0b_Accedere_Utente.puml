@startuml
title UC0b - Accesso al Sistema
skinparam actorStyle awesome

actor "Cliente / Negoziante" as Utenti
participant "InterfacciaLogin" <<boundary>>
participant "SistemaAccesso" as Sistema <<control>>
participant "UtenteRepository" as Repo <<repository>>
participant "Utente" <<entity>> 

Utenti -> InterfacciaLogin : Accede alla pagina di login
activate InterfacciaLogin
InterfacciaLogin -> Utenti : richiediCredenziali()
deactivate InterfacciaLogin

Utenti -> InterfacciaLogin : Inserisce credenziali
activate InterfacciaLogin

InterfacciaLogin -> Sistema : getSessione()
activate Sistema
Sistema --> InterfacciaLogin : sessioneCorrente
deactivate Sistema

InterfacciaLogin -> Sistema : inviaCredenziali(username, password)
activate Sistema
deactivate InterfacciaLogin

Sistema -> Sistema : verificaFormatoEmail(email)

Sistema -> Repo : trovaPerCredenziali(username, password)
activate Repo
Repo -> Utente : getUsername()
Repo -> Utente : getPassword()
Repo -> Utente : getEmail()
Repo -> Utente : getRuolo()
activate Utente
Utente --> Repo : ruolo
deactivate Utente
Repo --> Sistema : utente (oggetto o None)
deactivate Repo

alt Credenziali errate (utente == None) [ValueError]
    Sistema -> InterfacciaLogin : Messaggio "Credenziali non valide."
    activate InterfacciaLogin
    InterfacciaLogin -> Utenti : mostraErroreLogin()
    deactivate InterfacciaLogin
else Credenziali corrette (utente != None)
    
    Sistema -> Sistema : impostaSessione(ruolo)
    
    Sistema -> Sistema : reindirizzaPerRuolo(ruolo)
    
    Sistema -> Sistema : confrontaPassword(password, password)

    alt ruolo == "cliente"
        Sistema -> InterfacciaLogin : Reindirizza a InterfacciaCliente
        activate InterfacciaLogin
        InterfacciaLogin -> Utenti : mostraDashboardCliente()
        deactivate InterfacciaLogin
    else ruolo == "negoziante"
        Sistema -> InterfacciaLogin : Reindirizza a InterfacciaNegoziante
        activate InterfacciaLogin
        InterfacciaLogin -> Utenti : mostraDashboardNegoziante()
        deactivate InterfacciaLogin
    end
end

deactivate Sistema
@enduml