@startuml
title UC12b - Modificare fornitore
skinparam actorStyle awesome

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreFornitori" as GF <<control>>
participant "CatalogoFornitori" as CF <<repository>>
participant "Fornitore" as F <<entity>>

N -> IN: Seleziona fornitore da modificare
activate IN
IN -> GF: getFornitore(id)
activate GF
GF -> CF: trovaPerId(id)
activate CF
CF --> GF: fornitore
deactivate CF
GF --> IN: dettagli fornitore
deactivate GF
IN --> N: mostra form modifica (precompilato)

N -> IN: Modifica i campi (nome, contatti, tipologia, domicilio)
IN -> GF: modificaFornitore(id, nome, contatti, tipologia, domicilio)
activate GF

GF -> CF: trovaPerId(id)
activate CF
CF --> GF: fornitore esistente
deactivate CF
GF -> GF: validaDatiFornitore(nuoviDati)

alt fornitore non trovato
    GF --> IN: ValueError "Fornitore con id={id} non trovato."
    IN --> N: mostraErrore()
else fornitore trovato
    GF -> CF: cercaFornitore(fornitore)
    activate CF
    CF --> GF: fornitore confermato
    deactivate CF

    GF -> F: aggiornaProprietà(nuoviDati)
    GF -> CF: aggiornaFornitore(id, dati)
    activate CF
    CF --> GF: fornitore aggiornato
    deactivate CF

    GF -> GF: aggiornaListaFornitori()

    GF --> IN: esito positivo
    deactivate GF
    IN --> N: mostra "Fornitore modificato con successo"
end

deactivate IN
@enduml