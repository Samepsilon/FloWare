@startuml
title UC9b - Modificare articolo
skinparam actorStyle awesome

actor "Negoziante" as N
participant "InterfacciaNegoziante" as IN <<boundary>>
participant "GestoreCatalogo" as GC <<control>>
participant "CatalogoArticoli" as CA <<repository>>
participant "CatalogoFornitori" as CF <<repository>>
participant "Articolo" as A <<entity>>

N -> IN: Accede a "Gestione Catalogo"
activate IN
IN -> GC: visualizzaCatalogo()
activate GC
GC -> CA: getArticoliDisponibili()
activate CA
CA --> GC: elenco articoli
deactivate CA
GC --> IN: mostraElencoArticoli(articoli)
IN --> N: Mostra catalogo

N -> IN: Seleziona articolo da modificare

IN -> GC: richiediDettagli(idArticolo)
GC -> CA: trovaPerId(id)
activate CA
CA --> GC: articolo
deactivate CA
GC --> IN: dettagli articolo
deactivate GC
IN --> N: mostra form modifica (precompilato)

N -> IN: Modifica i campi (nome, descrizione, prezzo, ecc.)
IN -> GC: validaArticolo(articolo)
activate GC

GC -> CA: trovaPerId(id)
activate CA
CA --> GC: articolo esistente
deactivate CA
GC -> CA: verificaArticolo()
activate CA
CA --> GC: articolo verificato
deactivate CA

alt articolo non trovato
    GC --> IN: ValueError "Articolo con id={id} non trovato."
    IN --> N: mostraErrore()
else articolo trovato
    opt fornitore_id != None
        GC -> CF: cercaFornitore(id)
        activate CF
        CF --> GC: fornitore (o None)
        deactivate CF

        alt fornitore non trovato
            GC --> IN: ValueError "Fornitore con id={fornitore_id} non esiste."
            IN --> N: mostraErrore()
        end
    end

    GC -> A: getDettagli()
    GC -> CA: salva(articolo)
    activate CA
    CA --> GC: articolo aggiornato
    deactivate CA

    GC --> IN: esito positivo
    deactivate GC
    IN --> N: mostra "Articolo modificato con successo"
end

deactivate IN
@enduml